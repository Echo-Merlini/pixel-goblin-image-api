# Ethereum mainnet RPC — only eth_call is used (no getLogs/archive), so any free tier works.
RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
# Pixel Goblins mint-controller contract
CONTRACT=0x6559807ffd23965d3af54ee454bc69f113ed06ef
# ETHscriptions indexer (only used by the scrape, and as a runtime fallback for un-baked mints)
ETHSCRIPTIONS_API=https://api.ethscriptions.com/api/ethscriptions
COLLECTION_SLUG=pixel-goblins
# Public base URL of this service (used to build the image URL in metadata). Optional; inferred from request if unset.
PUBLIC_BASE_URL=https://pixel-goblin-image-api-production.up.railway.app
